# Copy this file to .env before running `docker compose up`.
# Do not commit real secrets or local credentials.

# Compose project name.
COMPOSE_PROJECT_NAME=bkg

# Optional vector-search profile.
# Set to "vector-search" to start Qdrant automatically.
# COMPOSE_PROFILES=vector-search

# PostgreSQL 16 with pgvector.
POSTGRES_DB=bkg
POSTGRES_USER=bkg
POSTGRES_PASSWORD=change-me-local-postgres-password
POSTGRES_PORT=5432

# Redis 7 for BullMQ queues and caching.
REDIS_PASSWORD=change-me-local-redis-password
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb

# MinIO S3-compatible object storage.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-local-minio-root-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=bkg-assets
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1

# Optional Qdrant vector search service.
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT__SERVICE__HTTP_PORT=6333
QDRANT__SERVICE__GRPC_PORT=6334
QDRANT__SERVICE__API_KEY=
